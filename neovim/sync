#!/bin/sh
# Sync this Neovim config into ~/.config/nvim (symlinks), or verify it.
#   ./sync          install / refresh the symlinks
#   ./sync verify   check each link still points back into this repo
#
# A pre-existing config that isn't already linked to this repo is backed up
# wholesale to ~/.config/nvim.bak.<timestamp>. Re-running once installed is a
# no-op that just refreshes the symlinks.
set -e

SRC="$(cd "$(dirname "$0")" && pwd)"   # the neovim/ dir in this repo
DEST="$HOME/.config/nvim"
ITEMS="init.vim lazy-lock.json"

# Confirm every installed path is still a symlink resolving to this repo. Catches
# the two ways the link can rot: replaced by a real file (silent divergence) or
# left dangling (repo moved/renamed, or target absent on the checked-out commit).
# Inode churn from git checkout/pull is fine by design — symlinks resolve by path.
verify() {
    rc=0
    for item in $ITEMS; do
        link="$DEST/$item"
        target="$SRC/$item"
        if [ ! -L "$link" ]; then
            echo "FAIL $link is not a symlink (run ./sync to fix)"
            rc=1
        elif [ "$(readlink "$link")" != "$target" ]; then
            echo "FAIL $link -> $(readlink "$link") (expected $target)"
            rc=1
        elif [ ! -e "$link" ]; then
            echo "FAIL $link is a dangling symlink -> $target (target missing)"
            rc=1
        else
            echo "OK   $link -> $target"
        fi
    done
    return "$rc"
}

if [ "$1" = "verify" ]; then
    verify
    exit
fi

# Only ever install from the canonical master branch. A worktree or feature
# branch checks out under a different branch name, and linking from one would
# point ~/.config/nvim at a path that vanishes when that checkout is removed —
# leaving dangling links. Read-only verify (handled above) stays allowed
# everywhere; pass FORCE=1 to override deliberately.
branch=$(git -C "$SRC" symbolic-ref --short -q HEAD 2>/dev/null || true)
if [ "${FORCE:-}" != "1" ] && [ -n "$branch" ] && [ "$branch" != "master" ]; then
    echo "sync: refusing to install from branch '$branch' — run from master (the canonical checkout)." >&2
    echo "sync: './sync verify' works anywhere; use FORCE=1 ./sync to override." >&2
    exit 1
fi

# Back up a pre-existing real config dir, then (re)link each item.
if [ -e "$DEST" ] && [ "$(readlink "$DEST/init.vim" 2>/dev/null)" != "$SRC/init.vim" ]; then
    backup="$DEST.bak.$(date +%Y%m%d%H%M%S)"
    echo "Backing up existing $DEST -> $backup"
    mv "$DEST" "$backup"
fi

mkdir -p "$DEST"
for item in $ITEMS; do
    if [ -e "$SRC/$item" ]; then
        ln -sfn "$SRC/$item" "$DEST/$item"
        echo "Linked $DEST/$item -> $SRC/$item"
    fi
done
