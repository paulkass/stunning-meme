prefix_rule(
  pattern = ["ls"],
  decision = "allow",
  justification = "Listing files is safe.",
)

prefix_rule(
  pattern = ["pwd"],
  decision = "allow",
  justification = "Printing the current directory is safe.",
)

prefix_rule(
  pattern = ["cat"],
  decision = "allow",
  justification = "Reading files is safe inside the sandbox.",
)

prefix_rule(
  pattern = ["sed"],
  decision = "allow",
  justification = "Text inspection is safe inside the sandbox.",
)

prefix_rule(
  pattern = [["rg", "grep", "find"]],
  decision = "allow",
  justification = "Search commands are safe inside the sandbox.",
)

prefix_rule(
  pattern = [["head", "tail", "wc", "file", "stat"]],
  decision = "allow",
  justification = "File inspection commands are safe.",
)

prefix_rule(
  pattern = ["git", ["status", "diff", "log", "show", "branch"]],
  decision = "allow",
  justification = "Read-only git inspection is safe.",
)

prefix_rule(
  pattern = ["git", ["add", "commit", "push", "reset", "checkout", "switch", "clean", "rebase", "merge"]],
  decision = "allow",
  justification = "Git mutation should be reviewed.",
)

prefix_rule(
  pattern = [["rm", "rmdir", "mv", "cp", "chmod", "chown", "sudo", "curl", "wget"]],
  decision = "prompt",
  justification = "Potentially destructive, privilege-changing, or network command.",
)
prefix_rule(pattern=["sort"], decision="allow")
prefix_rule(pattern=["git", "ls-files"], decision="allow")
